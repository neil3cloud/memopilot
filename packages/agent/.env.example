# MemoPilot Backend Environment Variables
# Copy this file to packages/agent/.env and fill in your values
# OR use ~/.memopilot/config.yaml for workspace-scoped configuration

# ============================================================================
# LOCAL DEVELOPMENT
# ============================================================================

# FastAPI server configuration
MEMOPILOT_HOST=127.0.0.1
MEMOPILOT_PORT=0  # 0 = auto-assign; written to agent.lock and read by extension
MEMOPILOT_RELOAD=true  # Auto-reload on file changes during development

# Database
DATABASE_URL=sqlite:///./memopilot.db  # Relative to working directory
DATABASE_ECHO=false  # SQL query logging

# ============================================================================
# LLM PROVIDER KEYS (Optional - Cloud providers)
# ============================================================================

# OpenAI (gpt-4, gpt-4-turbo, gpt-4o, gpt-4o-mini)
OPENAI_API_KEY=sk-...  # https://platform.openai.com/api-keys
OPENAI_MODEL=gpt-4o-mini  # Recommended for cost

# Anthropic (Claude 3 Opus/Sonnet/Haiku)
ANTHROPIC_API_KEY=sk-ant-...  # https://console.anthropic.com/
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022  # Latest Sonnet

# Google Gemini (optional)
GOOGLE_API_KEY=...  # https://ai.google.dev/

# ============================================================================
# LOCAL LLM PROVIDERS (Free, runs on your machine)
# ============================================================================

# Ollama (https://ollama.ai)
# Download models: ollama pull llama2, ollama pull mistral, etc.
OLLAMA_BASE_URL=http://localhost:11434  # Default Ollama port
OLLAMA_MODEL=mistral  # Recommended: mistral, neural-chat, or orca-mini

# LM Studio (https://lmstudio.ai)
LM_STUDIO_BASE_URL=http://localhost:1234  # Default LM Studio port

# ============================================================================
# VISION/IMAGE ANALYSIS (Optional)
# ============================================================================

# Local vision model via Ollama (free)
# ollama pull llava  (or llava-phi, bakllava)
OLLAMA_VISION_MODEL=llava

# Cloud vision APIs (optional fallback if Ollama unavailable)
# OpenAI Vision (gpt-4o, gpt-4o-mini support vision)
OPENAI_VISION_ENABLED=false

# Anthropic Vision (Claude 3 Opus/Sonnet support vision)
ANTHROPIC_VISION_ENABLED=false

# ============================================================================
# COST GUARD & BUDGET
# ============================================================================

# Monthly spend limit across all providers (in USD)
# Set to 0 for unlimited (not recommended for production)
MAX_MONTHLY_SPEND_USD=50.0

# Per-task token limits
MAX_CONTEXT_TOKENS=8000
MAX_GENERATION_TOKENS=4000
MAX_RESPONSE_TOKENS=2000

# Provider preferences (comma-separated, tried in order)
# LOCAL providers: ollama, lm-studio
# CLOUD providers: anthropic, openai, google
PROVIDER_PRIORITY=ollama,lm-studio,anthropic,openai

# Restrict providers by model type
# local-only = only use Ollama/LM Studio
# cost-conscious = prefer cheaper models even if slower
# quality-first = prefer best models regardless of cost
PROVIDER_STRATEGY=local-only

# ============================================================================
# SECURITY & AUTHENTICATION
# ============================================================================

# HMAC token for HTTP API calls from extension
# Generated by BackendManager on first start, written to agent.lock
MEMOPILOT_TOKEN=...  # 32+ random bytes, base64-encoded

# JWT secret for future token-based auth (reserved)
# JWT_SECRET=...

# ============================================================================
# LOGGING & DEBUGGING
# ============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Enable SQL query logging (very verbose)
SQL_DEBUG=false

# Enable API request/response logging
API_DEBUG=false

# ============================================================================
# WORKSPACE & CONTEXT
# ============================================================================

# Auto-detect workspace profile on startup
AUTO_PROFILE_DETECT=true

# Rebuild memory indices on startup (useful if corrupted)
FORCE_REBUILD_INDICES=false

# ============================================================================
# ADVANCED (usually not needed)
# ============================================================================

# Max concurrent API requests
MAX_CONCURRENT_REQUESTS=10

# Request timeout in seconds
REQUEST_TIMEOUT=60

# Retry failed API calls (max attempts)
MAX_RETRIES=3

# Backoff multiplier for retries
RETRY_BACKOFF_BASE=2.0
