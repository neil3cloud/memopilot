{
  "name": "memopilot",
  "displayName": "MemoPilot",
  "description": "Rule-Aware, Local-Memory, Cost-Governed AI Development Agent",
  "version": "1.0.0",
  "publisher": "memopilot",
  "license": "MIT",
  "icon": "resources/marketplace-icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/neil3cloud/memopilot.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "memopilot",
          "title": "MemoPilot",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "memopilot": [
        {
          "id": "memopilot-status",
          "name": "Status"
        },
        {
          "id": "memopilot-profile",
          "name": "Workspace Profile"
        },
        {
          "id": "memopilot-memory",
          "name": "Memory Manager"
        },
        {
          "id": "memopilot-rules",
          "name": "Rules & Skills"
        },
        {
          "id": "memopilot-context",
          "name": "Context Pack"
        },
        {
          "id": "memopilot-cost",
          "name": "Cost Guard"
        },
        {
          "id": "memopilot-privacy",
          "name": "Privacy Dashboard"
        },
        {
          "id": "memopilot-evidence",
          "name": "Evidence Board"
        },
        {
          "id": "memopilot-history",
          "name": "Task History"
        },
        {
          "id": "memopilot-mcp",
          "name": "MCP Tools"
        }
      ]
    },
    "commands": [
      {
        "command": "memopilot.indexWorkspace",
        "title": "MemoPilot: Index Workspace Memory"
      },
      {
        "command": "memopilot.analyzeTask",
        "title": "MemoPilot: Analyze Current Task"
      },
      {
        "command": "memopilot.generateContextPack",
        "title": "MemoPilot: Generate Context Pack"
      },
      {
        "command": "memopilot.showCostReport",
        "title": "MemoPilot: Show Cost Report"
      },
      {
        "command": "memopilot.openRules",
        "title": "MemoPilot: Open Rules"
      },
      {
        "command": "memopilot.rebuildMemory",
        "title": "MemoPilot: Rebuild Memory"
      },
      {
        "command": "memopilot.openWorkspaceProfile",
        "title": "MemoPilot: Open Workspace Profile"
      },
      {
        "command": "memopilot.rebuildWorkspaceProfile",
        "title": "MemoPilot: Rebuild Workspace Profile"
      },
      {
        "command": "memopilot.validateWorkspaceProfile",
        "title": "MemoPilot: Validate Workspace Profile"
      },
      {
        "command": "memopilot.exportWorkspaceProfile",
        "title": "MemoPilot: Export Workspace Profile"
      },
      {
        "command": "memopilot.reviewMemory",
        "title": "MemoPilot: Review Memory"
      },
      {
        "command": "memopilot.showPrivacyDashboard",
        "title": "MemoPilot: Show Privacy Dashboard"
      },
      {
        "command": "memopilot.showProviderCapabilities",
        "title": "MemoPilot: Show Provider Capabilities"
      },
      {
        "command": "memopilot.replayAICall",
        "title": "MemoPilot: Replay AI Call"
      },
      {
        "command": "memopilot.manageSkillStore",
        "title": "MemoPilot: Manage Skill Store"
      },
      {
        "command": "memopilot.backupMemory",
        "title": "MemoPilot: Backup Memory"
      },
      {
        "command": "memopilot.restoreMemory",
        "title": "MemoPilot: Restore Memory"
      },
      {
        "command": "memopilot.optimizeToolsAndSkills",
        "title": "MemoPilot: Optimize Tools and Skills"
      },
      {
        "command": "memopilot.selectBudgetProfile",
        "title": "MemoPilot: Select Budget Profile"
      },
      {
        "command": "memopilot.classifyEvidenceSource",
        "title": "MemoPilot: Classify Evidence Source"
      },
      {
        "command": "memopilot.managePolicyPacks",
        "title": "MemoPilot: Manage Policy Packs"
      },
      {
        "command": "memopilot.runLocalAgentFlow",
        "title": "MemoPilot: Run Local Agent Flow"
      },
      {
        "command": "memopilot.manageWorkspaces",
        "title": "MemoPilot: Manage Workspaces"
      },
      {
        "command": "memopilot.attachEvidence",
        "title": "MemoPilot: Attach Evidence"
      },
      {
        "command": "memopilot.runInvestigation",
        "title": "MemoPilot: Run Investigation"
      },
      {
        "command": "memopilot.showPanel",
        "title": "MemoPilot: Open Panel"
      },
      {
        "command": "memopilot.reviewAppliedPatch",
        "title": "MemoPilot: Review Applied Patch",
        "icon": "$(shield)"
      },
      {
        "command": "memopilot.refreshMemoryReviewQueue",
        "title": "MemoPilot: Refresh Memory Review Queue",
        "icon": "$(refresh)"
      },
      {
        "command": "memopilot.restartBackend",
        "title": "MemoPilot: Restart Backend"
      }
    ],
    "languageModelTools": [
      {
        "name": "memopilot_context",
        "displayName": "MemoPilot Context",
        "modelDescription": "Retrieves governed, rule-aware, secret-redacted context from MemoPilot local project memory. Call before generating a patch.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "task_description": { "type": "string", "description": "The task or question being answered." },
            "files_in_focus": { "type": "array", "items": { "type": "string" }, "description": "Relevant file paths." },
            "task_type_hint": { "type": "string", "enum": ["bug_fix", "feature", "test_generation", "refactor", "security_review", "investigation", "documentation", "general"] }
          },
          "required": ["task_description"]
        }
      },
      {
        "name": "memopilot_rules",
        "displayName": "MemoPilot Rules",
        "modelDescription": "Returns active project rules and skills for the current workspace.",
        "inputSchema": { "type": "object", "properties": {} }
      },
      {
        "name": "memopilot_memory_search",
        "displayName": "MemoPilot Memory Search",
        "modelDescription": "Searches MemoPilot local memory. Use when encountering an unfamiliar symbol or concept.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "query": { "type": "string", "description": "Symbol, concept, or phrase to search for." },
            "limit": { "type": "integer", "minimum": 1, "maximum": 20, "default": 10 }
          },
          "required": ["query"]
        }
      },
      {
        "name": "memopilot_workspace_profile",
        "displayName": "MemoPilot Workspace Profile",
        "modelDescription": "Returns workspace profile: language, frameworks, test commands, memory health.",
        "inputSchema": { "type": "object", "properties": {} }
      },
      {
        "name": "memopilot_patch_review",
        "displayName": "MemoPilot Patch Review",
        "modelDescription": "Reviews an applied patch against project rules. Call after applying changes to check compliance and risk.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "git_diff": { "type": "string", "description": "Optional diff text. If omitted, reads current git diff." }
          }
        }
      },
      {
        "name": "memopilot_writeback",
        "displayName": "MemoPilot Writeback",
        "modelDescription": "IMPORTANT: Call after applying a patch that used memopilot_context. Records what changed in project memory.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "outcome_summary": { "type": "string", "description": "What was accomplished." },
            "outcome_status": { "type": "string", "enum": ["success", "partial", "reverted"] },
            "context_pack_hash": { "type": "string", "description": "Optional hash from preceding memopilot_context call." },
            "git_diff": { "type": "string", "description": "Optional diff text." }
          },
          "required": ["outcome_summary", "outcome_status"]
        }
      }
    ],
    "configuration": {
      "title": "MemoPilot",
      "properties": {
        "memopilot.pythonPath": {
          "type": "string",
          "default": "",
          "description": "Path to the Python interpreter for the MemoPilot backend. If empty, auto-detects from workspace .venv or PATH."
        },
        "memopilot.backendLogLevel": {
          "type": "string",
          "enum": [
            "debug",
            "info",
            "warning",
            "error"
          ],
          "default": "info",
          "description": "Log level for the Python backend."
        }
      }
    }
  },
  "scripts": {
    "build": "esbuild ./src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node --sourcemap",
    "watch": "esbuild ./src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node --sourcemap --watch",
    "lint": "eslint src --ext ts",
    "test": "pnpm run build && tsc -p . && node ./out/test/runTests.js",
    "prebundle-agent": "node -e \"const fs=require('fs');fs.rmSync('agent',{recursive:true,force:true});fs.cpSync('../agent/agent','agent',{recursive:true})\"",
    "package": "pnpm run build && pnpm run prebundle-agent && vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@vscode/codicons": "^0.0.45",
    "@vscode/test-electron": "^3.0.0",
    "@vscode/vsce": "^2.22.0",
    "esbuild": "^0.20.0",
    "eslint": "^8.56.0",
    "mocha": "^10.8.2",
    "typescript": "^5.3.3"
  }
}
